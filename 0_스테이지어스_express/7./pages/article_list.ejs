<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="../css/index.css">
    <link rel="stylesheet" type="text/css" href="../css/web_page/article_list.css">
    <title>자유게시판</title>
</head>
<body>
    <nav onmouseleave="HideWideNavEvent()">
        <span id="goMain"></span>
        <span id="introduceBtn" class="navBtn" onmouseover="ShowWideNavEvent(this)" onmouseout="HideSvgEvent(this, 0)">자기소개</span>
        <span id="hwBtn" class="navBtn" onmouseover="ShowWideNavEvent(this)" onmouseout="HideSvgEvent(this, 0)">과제들 </span>
        <span id="boardBtn" class="navBtn" onmouseover="ShowWideNavEvent(this)" onmouseout="HideSvgEvent(this, 0)">게시판</span>
        
        <div id="fullSelectArea">
            <div class="fullSelectSeg"  onmouseover="ShowSvgEvent(this, 1)" onmouseout="HideSvgEvent(this, 1)">
                <div class="svgContain">
                    <p id="introduceBtnLine" class="btnLine"></p>
                    <svg id="introduceBtnSvgTri" class="svgTri">
                        <path d="M 10 10 L 20 0 L 0 0"></path>
                    </svg>
                </div>
                <div class="fullBtn">자기소개</div>
            </div>
            
            <div class="fullSelectSeg" onmouseover="ShowSvgEvent(this, 1)" onmouseout="HideSvgEvent(this, 1)">
                <div class="svgContain">
                    <p id="hwBtnLine" class="btnLine"></p>
                    <svg id="hwBtnSvgTri" class="svgTri">
                        <path d="M 10 10 L 20 0 L 0 0"></path>
                    </svg>
                </div>
                <div class="fullBtn">컴퓨터 견적</div>
                <div class="fullBtn">유튜브</div>
                <div class="fullBtn">숫자야구</div>
                <div class="fullBtn">사진퍼즐</div>
          </div>
            
            <div class="fullSelectSeg fullSelectSegEnd" onmouseover="ShowSvgEvent(this, 1)" onmouseout="HideSvgEvent(this, 1)">
                <div class="svgContain">
                    <p id="boardBtnLine" class="btnLine"></p>
                    <svg id="hwBtnSvgTri" class="svgTri">
                        <path d="M 10 10 L 20 0 L 0 0"></path>
                    </svg>
                </div>
                <div class="fullBtn" onclick="goBoardEvent(`Freeboard`)">자유게시판</div>
            </div>
        </div>
       
        <div id="menu" onclick="ShowMyBannerEvent()">=</div>
    </nav>
    
    <div id = "myBanner">
        <div id="menu" onclick="HideMyBannerEvent()">X</div>
        <span id="loginText">로그인해주세요</span>
        
        <div id="loginSeg">
            <div>
                <input type="text" id="id" class="loginInput">
                <input type="password" id="pw" class="loginInput">
            </div>
            <input type="button" id="loginBtn" value="로그인" onclick="loginEvent()"></span>
        </div>

        <div id="userSector">
            
        </div>

        <div id="logout" onclick="logoutEvent()">로그아웃</div>
    </div>


    <div id="contain">
        <div id="writeCtn">
            <div id="newBtn" onclick="addWriteAreaEvent()">새 글을 작성해주세요!</div>
        </div>
        <h2>자유게시판</h2>
    </div>
    
    <script src="/js/index.js"></script>
    <script src="/js/web_page/article_list.js"></script>

    <script>
        const readArticleEvent = (id) => {
            location.href = `/article/Freeboard/${id}`
        }

        let articleList = <%- JSON.stringify(result) %>
        articleList = articleList.message

        
        for(let idx in articleList){
            const cur =  articleList[idx]
            
            let ctn = document.createElement("div")
            ctn.id = cur.articleno
            ctn.className = `articleCtn`
            ctn.addEventListener("click", () => readArticleEvent(ctn.id))
            
            let id = document.createElement("p")
            id.className = "id"
            id.innerHTML = `작성자 : ${cur.id}`

            let title = document.createElement("p")
            title.className = "title"
            title.innerHTML = cur.title

            let regWhen = document.createElement("p")
            regWhen.className = "id"
            regWhen.innerHTML = cur.regwhen.substr(0, 10)
            
            ctn.appendChild(id)
            ctn.appendChild(title)
            ctn.appendChild(regWhen)
            document.getElementById("contain").appendChild(ctn)
        }
    </script>
</body>
</html>