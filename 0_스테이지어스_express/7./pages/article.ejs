<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="/css/index.css">
    <link rel="stylesheet" type="text/css" href="/css/web_page/article.css">
    <title>자유게시판</title>
</head>

<body>
    <nav onmouseleave="HideWideNavEvent()">
        <span id="goMain"></span>
        <span id="introduceBtn" class="navBtn" onmouseover="ShowWideNavEvent(this)" onmouseout="HideSvgEvent(this, 0)">자기소개</span>
        <span id="hwBtn" class="navBtn" onmouseover="ShowWideNavEvent(this)" onmouseout="HideSvgEvent(this, 0)">과제들 </span>
        <span id="boardBtn" class="navBtn" onmouseover="ShowWideNavEvent(this)" onmouseout="HideSvgEvent(this, 0)">게시판</span>
        
        <div id="fullSelectArea">
            <div class="fullSelectSeg"  onmouseover="ShowSvgEvent(this, 1)" onmouseout="HideSvgEvent(this, 1)">
                <div class="svgContain">
                    <p id="introduceBtnLine" class="btnLine"></p>
                    <svg id="introduceBtnSvgTri" class="svgTri">
                        <path d="M 10 10 L 20 0 L 0 0"></path>
                    </svg>
                </div>
                <div class="fullBtn">자기소개</div>
            </div>
            
            <div class="fullSelectSeg" onmouseover="ShowSvgEvent(this, 1)" onmouseout="HideSvgEvent(this, 1)">
                <div class="svgContain">
                    <p id="hwBtnLine" class="btnLine"></p>
                    <svg id="hwBtnSvgTri" class="svgTri">
                        <path d="M 10 10 L 20 0 L 0 0"></path>
                    </svg>
                </div>
                <div class="fullBtn">컴퓨터 견적</div>
                <div class="fullBtn">유튜브</div>
                <div class="fullBtn">숫자야구</div>
                <div class="fullBtn">사진퍼즐</div>
          </div>
            
            <div class="fullSelectSeg fullSelectSegEnd" onmouseover="ShowSvgEvent(this, 1)" onmouseout="HideSvgEvent(this, 1)">
                <div class="svgContain">
                    <p id="boardBtnLine" class="btnLine"></p>
                    <svg id="hwBtnSvgTri" class="svgTri">
                        <path d="M 10 10 L 20 0 L 0 0"></path>
                    </svg>
                </div>
                <div class="fullBtn" onclick="goBoardEvent(`Freeboard`)">자유게시판</div>
            </div>
        </div>
       
        <div id="menu" onclick="ShowMyBannerEvent()">=</div>
    </nav>
    
    <div id = "myBanner">
        <div id="menu" onclick="HideMyBannerEvent()">X</div>
        <span id="loginText">로그인해주세요</span>
        
        <div id="loginSeg">
            <div>
                <input type="text" id="id" class="loginInput">
                <input type="password" id="pw" class="loginInput">
            </div>
            <input type="button" id="loginBtn" value="로그인" onclick="loginEvent()"></span>
        </div>

        <div id="userSector">
            
        </div>

        <div id="logout" onclick="logoutEvent()">로그아웃</div>
    </div>

    <div id="contain">
        <h2>자유게시판</h2>
        <h3>
            <img class="profile" src="/source/web_page/profile.png">
            <div id="writerCtn"></div>
            <div id="validBtn">
                <span onclick="editEvent()">수정</span>
                <span onclick="removeEvent()">삭제</span>
            </div>
        </h3>
        <header id="title" class="header"></header>
        <main id="content" class="main"></main>
        <form id="articleContain" method="post" action="/article/Freeboard" enctype="multipart/form-data"></form>
    </div>
    <span id="articleNo" style="display: hidden;"></span>
</body>

<script>
    let result = <%- JSON.stringify(result) %>
    result = result.message

    document.getElementById("articleNo").value = result.articleno

    let writer = document.createElement("div")
    writer.id = `writer`
    writer.innerHTML = result.id
    document.getElementById("writerCtn").appendChild(writer)

    let regwhen = document.createElement("div")
    regwhen.id = `regwhen`
    regwhen.innerHTML = result.regwhen.substr(0, 10)
    document.getElementById("writerCtn").appendChild(regwhen)

    document.getElementById("title").innerHTML = result.title
    document.getElementById("content").innerHTML = result.content
    let imgSrc = result.imgsrc.split(`&`)

    let imgArea = document.createElement(`div`)
    imgArea.id = `displayImgArea`
    for(let idx in imgSrc){
        if(!imgSrc[idx])
            continue
        let img = document.createElement(`img`)
        img.src = imgSrc[idx]
        imgArea.appendChild(img)
    }
    document.getElementById(`content`).appendChild(imgArea)
</script>

<script src="/js/index.js"></script>
<script src="/js/web_page/article.js"></script>
</html>